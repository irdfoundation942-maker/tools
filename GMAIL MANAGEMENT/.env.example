# Flask configuration
FLASK_SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=1
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# OAuth / Gmail
GOOGLE_CLIENT_SECRETS_FILE=mail-management-credentials.json

# While developing over http (not https), Google OAuth requires this to be 1
OAUTHLIB_INSECURE_TRANSPORT=1

# Delay between outbound emails (seconds)
SEND_DELAY_SECONDS=2
